# Copia este archivo como .env y rellena con tus valores.
# No subas .env al repositorio (debe estar en .gitignore).

# Bucket Gold (obligatorio): mismo que usan capa_gold.py y gold_forecast.py
BUCKET_NAME_GOLD=tu-bucket-gold

# AWS: solo necesarios si la app corre en tu PC o en un entorno sin rol IAM.
# En EC2 con rol que tenga acceso al bucket Gold, no hace falta configurar keys.
# AWS_ACCESS_KEY_ID=tu_access_key_aqui
# AWS_SECRET_ACCESS_KEY=tu_secret_key_aqui
