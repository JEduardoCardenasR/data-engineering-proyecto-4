# =============================================================================
# Kafka – Variables de entorno (docker-compose y producer)
# =============================================================================
# Copia este archivo a .env y ajusta los valores para tu instancia.
# No subas .env al repositorio (debe estar en .gitignore).
#
# Flujo: producer.py publica en el topic weather_forecast; el consumer Spark
# (spark/app/consumer_forecast.py) lee ese topic y escribe Parquet en S3 RAW.
# Ver kafka/CONFIGURACION_KAFKA.md y spark/CONFIGURACION_SPARK_EC2.md (Consumer de forecast).
#
# Puertos en la red:
#   22   TCP   SSH (acceso al servidor)
#   9092 TCP   Puerto principal de Kafka (clientes: producers, consumers, Spark)
#   2181 TCP   Zookeeper – NO se usa en este proyecto (Kafka usa modo KRaft)
#   9093 TCP   Controller interno (KRaft). Opcional exponerlo; solo uso interno.
# =============================================================================

# -----------------------------------------------------------------------------
# Obligatorias
# -----------------------------------------------------------------------------

# IP privada de la instancia EC2 donde corre Kafka. Spark y otros clientes usan
# esta IP para conectar. Ejemplo: 172.31.38.86
KAFKA_IP=

# ID del cluster (KRaft). Generar uno con:
#   docker run --rm apache/kafka:3.7.0 kafka-storage random-uuid
# O usar un valor fijo que no cambie entre reinicios.
KAFKA_CLUSTER_ID=

# -----------------------------------------------------------------------------
# Opcionales (valores por defecto indicados)
# -----------------------------------------------------------------------------

# Puerto del broker (clientes conectan aquí). Por defecto 9092.
# Debe coincidir con el puerto abierto en el grupo de seguridad (SG).
KAFKA_PORT=9092

# ID del nodo en el cluster. Por defecto 1 (un solo broker).
KAFKA_NODE_ID=1

# Replicación de topics internos (1 = un solo broker).
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1

# Número de particiones por defecto para nuevos topics.
KAFKA_NUM_PARTITIONS=1

# Crear topics automáticamente cuando un producer/consumer publica o se suscribe.
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true

# -----------------------------------------------------------------------------
# Producer (producer.py) – OpenWeatherMap Forecast API → Kafka
# -----------------------------------------------------------------------------
# Si usas docker-compose, el servicio producer sobreescribe KAFKA_IP=kafka (red interna).
# KAFKA_IP en .env sigue siendo la IP de la instancia para el broker (clientes externos).

# Topic de pronósticos (forecast). Esquema distinto a openweather_topic (current weather).
# El pipeline Silver/Gold o un consumer nuevo debe tratar este esquema aparte.
KAFKA_TOPIC=weather_forecast

# Clave API de OpenWeatherMap. Obtenerla en: https://openweathermap.org/api
# No dejar vacía ni subir a repositorio.
OPENWEATHER_API_KEY=

# Ciudades separadas por punto y coma. Formato: "Nombre,código_país".
OPENWEATHER_CITIES=Patagonia,AR;Riohacha,CO

# Intervalo en segundos entre ráfagas de pronóstico. 600 = 10 min (recomendado para forecast).
POLL_SECS=600

# Límite de ráfagas (0 = sin límite). Útil para pruebas.
MAX_RUNS=0

# Si es true (o 1/yes), envía una sola ráfaga (todas las ciudades) y termina.
RUN_ONCE=false
