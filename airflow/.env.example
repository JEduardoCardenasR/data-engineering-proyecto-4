# Copia este archivo como .env y rellena con tus valores.
# No subas .env al repositorio (debe estar en .gitignore).
# En producción, define contraseñas seguras; no uses los valores por defecto.

AIRFLOW_UID=********
_AIRFLOW_WWW_USER_USERNAME=********
_AIRFLOW_WWW_USER_PASSWORD=********

# Base de datos PostgreSQL (Airflow)
# En producción obligatorio: usa contraseña segura y no dejes valores por defecto.
POSTGRES_USER=airflow
POSTGRES_PASSWORD=********
POSTGRES_DB=airflow

# Airbyte Cloud (OAuth2) - para que el DAG dispare syncs vía API
AIRBYTE_CLIENT_ID=tu_client_id_de_airbyte_cloud
AIRBYTE_CLIENT_SECRET=tu_client_secret_de_airbyte_cloud
AIRBYTE_CONNECTION_ID_PATAGONIA=uuid_conexion_patagonia
AIRBYTE_CONNECTION_ID_RIOHACHA=uuid_conexion_riohacha

# Opcionales (el DAG tiene valores por defecto)
# AIRFLOW_SSH_CONN_ID=ssh_spark_server
# SPARK_PROJECT_PATH=/home/ubuntu/spark-project

# DAG forecast_pipeline (Kafka → Gold): servidor Kafka y ruta del proyecto
# AIRFLOW_SSH_KAFKA_CONN_ID=ssh_kafka_server
# KAFKA_PROJECT_PATH=/home/ubuntu/kafka
